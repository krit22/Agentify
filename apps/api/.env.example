# Server Config
PORT=3000
NODE_ENV=development

# --- DATABASE ORM (Neon DB) ---
# Connection string for Prisma queries (Neon pooled connection string)
DATABASE_URL="postgresql://username:password@neon-host-pooler.neon.tech/dbname?sslmode=require"
# Direct connection string for Prisma migrations/commands (Neon unpooled connection string)
DIRECT_URL="postgresql://username:password@neon-host.neon.tech/dbname?sslmode=require"

# --- VECTOR DATABASE (Pinecone) ---
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX="aegis-ai"

# --- THIRD-PARTY SERVICES (For reference / future integration) ---
# Clerk Authentication
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Resend Email Integration
RESEND_API_KEY="re_..."

# OpenRouter AI & Embedding Services
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="nvidia/nemotron-3-ultra-550b-a55b:free"

# Unstructured.io Document Parsing
UNSTRUCTURED_API_KEY="your-unstructured-api-key"
UNSTRUCTURED_API_URL="https://api.unstructured.io/general/v0/general"
